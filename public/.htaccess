Options -MultiViews -Indexes
RewriteEngine On

# CRITICAL: Serve real files and directories as-is (JS, CSS, images, etc.)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Route /about/ → /about/index.html (Next.js trailingSlash: true)
RewriteCond %{REQUEST_FILENAME}/index.html -f
RewriteRule ^(.+?)/?$ $1/index.html [L]

# Fallback: everything else → root index.html
RewriteRule ^ /index.html [L]
